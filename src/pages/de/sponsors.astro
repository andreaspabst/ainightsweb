---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SponsorTiers from '../../components/SponsorTiers.astro';
---

<Layout
  lang="de"
  title="Unsere Sponsoren — AI Nights"
  description="Lerne die Unternehmen kennen, die die AI Nights möglich machen – von Platin- bis Bronze-Sponsoren."
  path="/de/sponsors/"
  alternates={{ de: '/de/sponsors/', en: '/en/our-sponsors/' }}
>
  <Header lang="de" />
  <main class="container section">
    <div class="head">
      <p class="eyebrow">Danke an unsere Partner</p>
      <h1 class="display-font">Unsere Sponsoren</h1>
      <p class="sub">Die fantastischen Unternehmen, die AI&nbsp;Nights möglich machen.</p>
    </div>
    <SponsorTiers lang="de" />
    <div class="cta">
      <p>Du willst die AI&nbsp;Nights unterstützen?</p>
      <a href="/de/sponsoring/" class="btn btn-primary">Sponsor werden</a>
    </div>
  </main>
  <Footer lang="de" />
</Layout>

<style>
  .head {
    text-align: center;
    margin-bottom: 3rem;
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin: 0.4rem 0 0.6rem;
  }
  .sub {
    color: var(--text-secondary);
    font-size: 1.05rem;
  }
  .cta {
    text-align: center;
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }
  .cta p {
    color: var(--text-secondary);
  }
</style>
