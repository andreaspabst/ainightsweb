---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Generischer Renderer für migrierte Text-/Rechts-/Danke-Seiten.
// Inhalte kommen aus src/data/pages/*.json (aus WordPress extrahiert).
const modules = import.meta.glob('../data/pages/*.json', { eager: true });

// Diese Pfade werden von eigenen, bespoke gestalteten Seiten bedient
// und dürfen hier NICHT erzeugt werden (sonst doppelte Route).
const BESPOKE = new Set([
  '/de/',
  '/en/',
  '/de/galerie/',
  '/de/sponsors/',
  '/en/our-sponsors/',
  '/de/tickets/',
  '/de/formate/',
]);

export async function getStaticPaths() {
  const modules = import.meta.glob('../data/pages/*.json', { eager: true });
  const BESPOKE = new Set([
    '/de/',
    '/en/',
    '/de/galerie/',
    '/de/sponsors/',
    '/en/our-sponsors/',
    '/de/tickets/',
    '/de/formate/',
  ]);
  return Object.values(modules)
    .map((m: any) => m.default ?? m)
    .filter((p: any) => p && p.path && !BESPOKE.has(p.path))
    .map((p: any) => ({
      params: { slug: p.path.replace(/^\/|\/$/g, '') },
      props: { page: p },
    }));
}

const { page } = Astro.props;
const lang = (page.lang === 'en' ? 'en' : 'de') as 'de' | 'en';
---

<Layout
  lang={lang}
  title={page.seoTitle ?? `${page.title} — AI Nights`}
  description={page.description ?? page.heroSubtitle ?? page.title}
  path={page.path}
>
  <Header lang={lang} />
  <main class="container page section">
    <header class="page-head">
      <h1 class="display-font">{page.title}</h1>
      {page.heroSubtitle && <p class="sub">{page.heroSubtitle}</p>}
    </header>
    {page.contentHtml && <div class="prose" set:html={page.contentHtml} />}
  </main>
  <Footer lang={lang} />
</Layout>

<style>
  .page {
    max-width: 820px;
    padding-block: 3rem 3rem;
  }
  .page-head {
    margin-bottom: 2rem;
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 0.6rem;
  }
  .sub {
    color: var(--text-secondary);
    font-size: 1.1rem;
    max-width: 60ch;
  }
</style>
