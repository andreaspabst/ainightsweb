---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import galleryData from '../../data/gallery.json';
import { isPlaceholderSpeaker } from '../../lib/speakers';
import { imgVariant } from '../../lib/images';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((e) => ({ params: { slug: e.data.slug }, props: { e } }));
}

const { e } = Astro.props;
const d = e.data;

// Foto-Rückblick dieses Events (falls vorhanden). Events ohne eigene Galerie
// (z. B. weil sie noch nicht stattgefunden haben) bekommen stattdessen einen
// bunt gemischten Vorgeschmack aus vergangenen AI Nights — Fotos aller Events
// im Round-Robin gemischt, damit nicht ein einzelnes Event dominiert.
const galleryGroup = (galleryData as { event: string; images: string[] }[]).find((g) => g.event === d.slug);
const hasOwnPhotos = (galleryGroup?.images.length ?? 0) > 0;
let eventPhotos = galleryGroup?.images.slice(0, 24) ?? [];

if (!hasOwnPhotos) {
  const pools = (galleryData as { event: string; images: string[] }[]).map((g) => g.images);
  const mixed: string[] = [];
  for (let i = 0; mixed.length < 20 && pools.some((p) => i < p.length); i++) {
    for (const p of pools) {
      if (p[i]) mixed.push(p[i]);
      if (mixed.length >= 20) break;
    }
  }
  eventPhotos = mixed;
}

// Community-Stimmen (wie auf der Startseite)
const testimonials = [
  'Sehr unterhaltsam und fachlich stark. Man merkt, dass hier echte Erfahrung auf der Bühne steht.',
  'Lockere Atmosphäre, starke Location und interessante Vorträge. Man fühlt sich sofort abgeholt und willkommen.',
  'Die Mischung aus Vortrags-Diversität und Live-Demos war top. Abwechslungsreich und nie langweilig.',
];

// Stimmen als Schriftform für den Parallax-Abschnitt weiter unten (aktualisiert:
// die AI Nights sind längst über Nürnberg hinausgewachsen)
const parallaxQuotes = [
  'Spannende Talks mit richtig guten Impulsen. Genau die Art Input, die zum Weiterdenken anregt.',
  'Die Mischung aus Vortrags-Diversität und Live-Demos war top. Abwechslungsreich und nie langweilig.',
  'Gute Themen, klare Pausen und endlich Zeit für echtes Networking. So entstehen Gespräche, die hängen bleiben.',
  'Lockere Atmosphäre, starke Location und interessante Vorträge. Man fühlt sich sofort abgeholt und willkommen.',
];
const parallaxBg = '/wp-content/uploads/2026/01/23-ianight-23-scaled.jpg';

// YouTube-Einblick „So fühlt sich AI Nights an“ (wie auf der aktuellen Seite)
const youtubeId = 'U-F1GZmbzJE';

// Gastgeber/Host-Vorstellung (statische Marken-Copy, wie auf der aktuellen Seite)
const hostImage = '/wp-content/uploads/2026/01/19-ianight-19-scaled.jpg';
const hostParagraphs = [
  'Ich beschäftige mich täglich mit der Frage, wie KI sinnvoll in Produkte, Prozesse und Teams integriert werden kann.',
  'Als Head of Engineering und KI-Enthusiast arbeite ich an der Schnittstelle von Technik, Produkt und Anwendung – von der Automatisierung einzelner Workflows bis hin zur Entwicklung AI-nativer Lösungen.',
  'Die AI Nights sind aus genau diesem Gedanken entstanden: Ein Ort für Austausch, ehrliche Fragen und unterschiedliche Perspektiven.',
  'Mir war wichtig, ein Format zu schaffen, das nicht überfordert, sondern Orientierung gibt. Mit kurzen Impulsen, genug Pausen und Zeit für Gespräche, die über die Bühne hinausgehen.',
];

// FAQ (wie auf der aktuellen Seite)
const faqItems = [
  { q: 'Was sind die AI Nights?', a: 'Die AI Nights sind ein Afterwork-Meetup rund um Künstliche Intelligenz. Mit kurzen Talks, drei Speaker pro Abend, moderierter Diskussion und viel Zeit für Austausch – offline, persönlich und auf Augenhöhe.' },
  { q: 'Wie läuft der Abend ab?', a: 'Der Einlass beginnt ab 17:00 Uhr und die Talks starten um 18:00 Uhr. Jeder Impuls dauert maximal 30 Minuten, dazwischen gibt es bewusst kurze Pausen. Im Anschluss (so ab 20:15/20:30 Uhr) bleibt ausreichend Zeit für Networking bei Snacks & Drinks. Den genauen Ablaufplan erhältst du ein paar Tage vor dem Event per E-Mail.' },
  { q: 'Wie funktioniert der Ticketkauf?', a: 'Ganz unkompliziert: Du sicherst dir dein Ticket hier online über unsere Website und wirst direkt an den Zahlungsanbieter Digistore24 weitergeleitet. Nach dem Kauf bekommst du ein digitales Ticket via E-Mail zugesendet, das du am Eventabend einfach auf dem Smartphone vorzeigst – ausdrucken ist nicht nötig.' },
  { q: 'Kann ich auch spontan kommen?', a: 'Ja! 🎉 Wenn noch Plätze verfügbar sind, gibt es eine Abendkasse. Du kannst also auch spontan vorbeikommen und vor Ort ein Ticket kaufen.\n👉 Tipp: Online-Tickets sind günstiger und garantieren dir sicher einen Platz.' },
  { q: 'Für wen sind die AI Nights gedacht?', a: 'Für alle, die KI verstehen, einordnen oder anwenden wollen – egal ob du aus Tech, Business, Recht, Produkt, Design kommst oder einfach neugierig bist. Du musst kein Vorwissen mitbringen.' },
  { q: 'Gibt es Zeit zum Netzwerken?', a: 'Ja – und zwar bewusst. Nach den Talks ist genug Zeit für Gespräche, Fragen und neue Kontakte. Kein Speed-Networking, kein Zwang – einfach echter Austausch.' },
  { q: 'Muss ich mich mit KI oder bestimmten Tools schon auskennen?', a: 'Nein. Du solltest technisches Grundverständnis mitbringen (z. B. als Entwickler:in oder Tech-Interessierte:r), aber du musst kein KI-Profi sein. Die Vorträge sind praxisnah und verständlich – und es ist genug Raum für Fragen!' },
  { q: 'Sind die AI Nights unabhängig oder steckt ein Unternehmen dahinter?', a: 'Die AI Nights sind ein unabhängiges Community-Format. Es geht nicht darum, Tools zu verkaufen oder Meinungen vorzugeben, sondern darum, Wissen, Erfahrungen und Perspektiven zu teilen. Was du daraus machst, entscheidest du selbst.' },
  { q: 'Wo finden die AI Nights statt?', a: 'Entweder in den 📍 Design Offices Nürnberg Hauptbahnhof oder in den 📍 Design Offices Nürnberg City, Königstorgraben 11, 5. OG. Moderne Location mit Platz für Austausch, Denken und Afterwork-Vibes – keine klassische Konferenz-Atmosphäre.\nKurzfristige Änderungen werden dir direkt über den Newsletter mitgeteilt.' },
  { q: 'Gibt es etwas zu Essen oder zu Trinken?', a: 'Ja. Getränke und Snacks sind im Ticketpreis enthalten, damit du ankommen, bleiben und dich auf Gespräche konzentrieren kannst.' },
  { q: 'Wie lange dauert das Event?', a: 'Ab 17:00 Uhr öffnen wir die Türen – Zeit zum Ankommen, Getränk schnappen und erste Gespräche führen. Der offizielle Teil startet um 18:00 Uhr.\nDie Talks dauern jeweils maximal 30 Minuten. Dazwischen gibt es bewusst 15 Minuten Pause – zum Durchatmen, Nachfragen und Austauschen.\nAb ca. 20:15 Uhr geht der Abend in ein offenes Networking über. Viele bleiben noch 1–2 Stunden, manche auch länger – ganz entspannt und ohne festen Zeitplan.' },
  { q: 'Ich bin unsicher, ob das das Richtige für mich ist.', a: 'Dann bist du vermutlich genau richtig. Die AI Nights sind für Menschen mit Fragen, Zweifel und Neugier – nicht nur für die, die schon alles wissen. Melde dich bei Fragen einfach bei uns direkt via Mail unter ping@ainights.ai' },
];

// „Kurz. Klar. Relevant.“ — Abschluss-Feature-Strip (wie auf der aktuellen Seite)
const closingFeatures = [
  { icon: '💡', label: 'Praxis-Impulse' },
  { icon: '🤝', label: 'Netzwerken' },
  { icon: '👀', label: 'Drei Perspektiven' },
  { icon: '🥂', label: 'Drinks & Snacks' },
  { icon: '❓', label: 'Fragen stellen' },
  { icon: '💬', label: 'Speaker-Austausch' },
];

// Location — eigene Sektion mit Bild statt nur einem Meta-Icon im Hero
const locationImage = eventPhotos[2] ?? eventPhotos[0] ?? '/wp-content/uploads/2026/01/1-34-publikum.jpg';
const mapsQuery = encodeURIComponent([d.locationName, d.locationAddress, d.city].filter(Boolean).join(', '));
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;

// Für wen sind die AI Nights? (basierend auf der bestehenden FAQ-Antwort, in drei Personas aufgeteilt)
const audiences = [
  { icon: '🚀', title: 'Neugierige & Einsteiger:innen', text: 'Du findest KI spannend, weißt aber noch nicht genau, wo du anfangen sollst? Perfekt — Vorwissen brauchst du nicht, nur Neugier.' },
  { icon: '💻', title: 'Tech & Produkt', text: 'Entwickler:innen und Produktleute, die wissen wollen, was in der Praxis wirklich funktioniert — nicht nur auf Folien.' },
  { icon: '📈', title: 'Business & Entscheider:innen', text: 'Du willst einordnen, wo KI im eigenen Unternehmen wirklich Mehrwert schafft — und wo (noch) nicht.' },
];

// Beziehungen (Post-IDs) zu Collection-Einträgen auflösen
const speakerColl = await getCollection('speaker');
const sessionColl = await getCollection('sessions');
const sponsorColl = await getCollection('sponsor');
const byId = (coll: any[]) => new Map(coll.filter((x) => x.data.id).map((x) => [x.data.id, x]));
const spMap = byId(speakerColl);
const seMap = byId(sessionColl);
const spoMap = byId(sponsorColl);

const resolve = (ids: number[] | undefined, m: Map<number, any>) =>
  (ids ?? []).map((id) => m.get(id)).filter(Boolean);

const speakerSlots = resolve(d.speakerIds, spMap);
const speakers = speakerSlots.filter((s) => !isPlaceholderSpeaker(s));
// Noch unbesetzte Slots (Platzhalter) als „Wird noch bekanntgegeben“ zeigen
const tbaCount = speakerSlots.length - speakers.length;
const moderators = resolve(d.moderatorIds, spMap);
// Komplettes Programm inkl. Pausen — wie im Original; Pausen werden schlanker dargestellt
const sessions = resolve(d.sessionIds, seMap);
const isBreak = (s: any) => /pause|break/i.test(s.data.title);
const sponsors = resolve(d.sponsorIds, spoMap);

// Meta-Badges einer Session (Bühne, Level) — Zeit/Dauer wandern in die Timeline-Spalte
function sessionMeta(s: any) {
  const m: string[] = [];
  if (s.data.room) m.push(s.data.room);
  if (s.data.level) m.push(String(s.data.level).charAt(0).toUpperCase() + String(s.data.level).slice(1));
  return m;
}

// Hero-Hintergrund: echtes Eventfoto statt des Branding-Bilds (das enthält
// eingebrannten Titeltext und kollidiert sonst mit der H1). Fallback: Publikumsfoto.
const heroBg = eventPhotos[0] ?? '/wp-content/uploads/2026/01/1-34-publikum.jpg';
// Bei Events ohne eigene Galerie stammt eventPhotos[1] aus einem anderen Event-Pool
// als das Hero-Bild und war stichprobenartig schlecht ausgeleuchtet. eventPhotos[4]
// ist im Round-Robin das zweite Bild aus demselben (gut ausgeleuchteten) Pool wie heroBg.
const factsImage = hasOwnPhotos
  ? (eventPhotos[1] ?? eventPhotos[0] ?? '/wp-content/uploads/2026/01/1-34-publikum.jpg')
  : (eventPhotos[4] ?? eventPhotos[0] ?? '/wp-content/uploads/2026/01/1-34-publikum.jpg');

function fmtDate(dt?: string) {
  if (!dt) return null;
  const p = new Date(dt);
  if (isNaN(p.getTime())) return dt;
  return p.toLocaleDateString('de-DE', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' });
}
const dateLabel = fmtDate(d.eventDate);
const isPast = d.eventDate ? new Date(d.eventDate) < new Date('2026-07-14') : false;
const countdownTarget = !isPast && d.eventDate ? `${d.eventDate}T${d.startTime ?? '18:00'}:00` : null;

// Programm-Struktur für die Kurzfakten: die eigentlichen Talks (ohne Welcome/
// Kickoff und ohne Pausen) laufen je 30 Minuten inkl. Zeit für Austausch;
// dazwischen liegen separate 15-minütige Pausen.
const isWelcome = (s: any) => /welcome|kickoff/i.test(s.data.title);
const coreTalks = sessions.filter((s) => !isBreak(s) && !isWelcome(s));
const breaks = sessions.filter((s) => isBreak(s));
const talkDuration = coreTalks.find((s) => s.data.duration)?.data.duration;
const breakDuration = breaks.find((s) => s.data.duration)?.data.duration;

// Einlasszeit (Türöffnung) weicht meist vom Programmstart ab — separat ausweisen
const firstTalkTime = sessions.find((s) => !isBreak(s))?.data.startTime;
const showDoors = Boolean(d.startTime && firstTalkTime && d.startTime !== firstTalkTime);

const facts: { icon: string; label: string }[] = [
  { icon: '🎤', label: `${speakerSlots.length || 3} Speaker${moderators.length ? ' & ' + moderators.length + ' Moderator' : ''}` },
  { icon: '🤖', label: '100% KI-Fokus' },
  {
    icon: '🗂️',
    label: coreTalks.length
      ? `${coreTalks.length} Sessions${talkDuration ? ` à ${talkDuration} Min.` : ''} inkl. Austausch`
      : 'Kurze Impuls-Sessions',
  },
  ...(breaks.length ? [{ icon: '☕', label: `Pausen${breakDuration ? ` à ${breakDuration} Min.` : ''}` }] : []),
  { icon: '🤝', label: 'Speaker den ganzen Abend verfügbar' },
  { icon: '🥂', label: 'Inklusive Drinks & Snacks' },
];
---

<Layout
  lang="de"
  title={d.seo?.title ?? `${d.title} — AI Nights`}
  description={d.seo?.description ?? d.excerpt ?? `${d.title} — ein AI Nights Afterwork-Event${d.city ? ` in ${d.city}` : ''}.`}
  path={`/events/${d.slug}/`}
  image={d.image?.src}
  ogType="event"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Event',
    name: d.title,
    startDate: d.eventDate,
    eventStatus: 'https://schema.org/EventScheduled',
    eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
    location: d.locationName
      ? { '@type': 'Place', name: d.locationName, address: d.locationAddress ?? d.city }
      : undefined,
    image: d.image?.src ? `https://ainights.ai${d.image.src}` : undefined,
    description: d.excerpt,
    performer: speakers.map((s) => ({ '@type': 'Person', name: s.data.title })),
    organizer: { '@type': 'Organization', name: 'AI Nights', url: 'https://ainights.ai' },
  }}
>
  <Header lang="de" />
  <main>
    <section class="hero">
      <img class="hero-bg" src={imgVariant(heroBg, 1600)} alt="" role="presentation" data-parallax="10" data-parallax-scale="1.12" />
      <div class="hero-duotone"></div>
      <div class="hero-overlay"></div>
      <div class="hero-stars" data-parallax="5"></div>
      <div class="hero-orb hero-orb-a"></div>
      <div class="hero-orb hero-orb-b"></div>
      <div class="container hero-inner">
        <a href="/events/" class="back">← Alle Events</a>
        <div class="badges">
          {d.city && <span class="badge">📍 {d.city}</span>}
          <span class="badge badge-outline">🌙 Afterwork</span>
          {isPast && <span class="badge past">Vergangenes Event</span>}
        </div>
        <p class="kicker">{dateLabel ? `Afterwork am ${new Date(d.eventDate!).toLocaleDateString('de-DE')}` : 'Afterwork Event'}</p>
        <h1 class="display-font">{d.title}</h1>

        <div class="hero-chips">
          {dateLabel && <span class="hero-chip"><span class="hc-icon">📅</span>{dateLabel}</span>}
          {d.startTime && <span class="hero-chip"><span class="hc-icon">🕕</span>{d.startTime} Uhr</span>}
          {d.locationName && <span class="hero-chip"><span class="hc-icon">📍</span>{d.locationName}</span>}
        </div>

        <div class="hero-bar">
          {speakers.length > 0 && (
            <a href="#lineup" class="hero-bar-speakers">
              <span class="hero-speakers-avatars">
                {speakers.slice(0, 5).map((s) => (
                  s.data.image?.src
                    ? <img src={imgVariant(s.data.image.src, 96)} alt="" loading="lazy" />
                    : <span class="hero-speakers-fallback">✨</span>
                ))}
              </span>
              <span class="hero-bar-speakers-label">{speakerSlots.length || speakers.length} Speaker ↓</span>
            </a>
          )}

          {countdownTarget && (
            <div class="hero-bar-countdown">
              <span class="hbc-dot"></span>
              <div class="countdown" data-countdown={countdownTarget}>
                <div class="cd-box"><strong data-cd-d>00</strong><span>Tage</span></div>
                <div class="cd-sep">:</div>
                <div class="cd-box"><strong data-cd-h>00</strong><span>Std</span></div>
                <div class="cd-sep">:</div>
                <div class="cd-box"><strong data-cd-m>00</strong><span>Min</span></div>
                <div class="cd-sep">:</div>
                <div class="cd-box"><strong data-cd-s>00</strong><span>Sek</span></div>
              </div>
            </div>
          )}

          {d.ticketUrl && !isPast && <a href={d.ticketUrl} target="_blank" rel="noopener" class="btn btn-primary hero-bar-cta">Tickets sichern</a>}
        </div>
      </div>
      <svg class="hero-divider" viewBox="0 0 1440 90" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0,32 C220,80 420,0 720,28 C1020,56 1220,84 1440,24 L1440,90 L0,90 Z"></path>
      </svg>
    </section>

    <div class="container body">
      {(d.contentHtml || d.excerpt) && (
        <div class="intro prose" data-reveal>
          {d.contentHtml ? <div set:html={d.contentHtml} /> : <p>{d.excerpt}</p>}
        </div>
      )}

      {/* Programm — als Kachel-Stack: jede Karte bleibt beim Scrollen kurz stehen,
          bis die nächste sich darüberschiebt. */}
      {sessions.length > 0 && (
        <section class="sec" data-reveal>
          <p class="eyebrow">Gespräche. Impulse. Perspektiven.</p>
          <h2 class="display-font sec-h">Die <span class="gradient-text">Themen</span> des Abends</h2>
          {showDoors && (
            <div class="stack-note">
              <span class="note-pill">🚪 Einlass ab {d.startTime} Uhr</span>
            </div>
          )}
          <div class="stack">
            {sessions.map((s, i) => {
              const sp = (s.data.speakerIds ?? [])
                .map((id: number) => spMap.get(id))
                .filter(Boolean)
                .filter((x: any) => !isPlaceholderSpeaker(x));
              const meta = sessionMeta(s);
              if (isBreak(s)) {
                return (
                  <div class="stack-card stack-break" style={`--i:${i}`}>
                    <span class="note-pill">☕ {s.data.title}{s.data.duration && ` · ${s.data.duration} min`}</span>
                  </div>
                );
              }
              return (
                <article class="stack-card" style={`--i:${i}`}>
                  <div class="stack-head">
                    {s.data.startTime && <span class="stack-time">🕕 {s.data.startTime} Uhr</span>}
                    {meta.map((m) => <span class="chip">{m}</span>)}
                    {s.data.duration && <span class="chip">{s.data.duration} min</span>}
                  </div>
                  <h3>{s.data.title}</h3>
                  {sp.length > 0 && (
                    <div class="talk-sp">
                      <span class="talk-sp-avatars">
                        {sp.map((x: any) => (
                          x.data.image?.src
                            ? <img src={imgVariant(x.data.image.src, 80)} alt="" loading="lazy" />
                            : <span class="talk-sp-fallback">✨</span>
                        ))}
                      </span>
                      <span class="talk-sp-names">{sp.map((x: any) => x.data.title).join(', ')}</span>
                    </div>
                  )}
                  {s.data.excerpt && <p class="talk-ex">{s.data.excerpt}</p>}
                  {s.data.contentHtml && s.data.contentHtml.replace(/<[^>]+>/g, '').trim().length > (s.data.excerpt?.length ?? 0) + 20 && (
                    <details class="talk-detail">
                      <summary>Mehr anzeigen</summary>
                      <div class="prose" set:html={s.data.contentHtml} />
                    </details>
                  )}
                </article>
              );
            })}
          </div>
        </section>
      )}

      {/* Fakten — farbiger Trenner mit Bild statt einer weiteren dunklen Karte */}
      <section class="facts" data-reveal>
        <div class="facts-orb facts-orb-a"></div>
        <div class="facts-orb facts-orb-b"></div>
        <div class="facts-grid">
          <div class="facts-img">
            <img src={imgVariant(factsImage, 640)} alt="" loading="lazy" />
          </div>
          <div class="facts-info">
            <h2 class="display-font">Das Afterwork-Event in <span class="gradient-text">Kürze</span></h2>
            <ul>
              {facts.map((f, i) => (
                <li>
                  <span class={`fact-icon fact-icon-${i % 2 === 0 ? 'a' : 'b'}`}>{f.icon}</span>
                  <span>{f.label}</span>
                </li>
              ))}
            </ul>
            <a
              href={!isPast && d.ticketUrl ? d.ticketUrl : '/de/tickets/'}
              target={!isPast && d.ticketUrl ? '_blank' : undefined}
              rel={!isPast && d.ticketUrl ? 'noopener' : undefined}
              class="btn btn-primary facts-cta"
            >
              {isPast ? 'Kommende Events ansehen' : 'Tickets sichern'}
            </a>
          </div>
        </div>
      </section>

      {/* Für wen ist das? */}
      <section class="sec" data-reveal>
        <p class="eyebrow">Passt das zu dir?</p>
        <h2 class="display-font sec-h">Für wen sind die <span class="gradient-text">AI Nights</span></h2>
        <div class="audience-grid">
          {audiences.map((a) => (
            <div class="audience-card">
              <span class="audience-icon">{a.icon}</span>
              <h3>{a.title}</h3>
              <p>{a.text}</p>
            </div>
          ))}
        </div>
      </section>

      {/* Stimmen aus der Community — Video-Testimonials wie im Original */}
      <section class="sec" data-reveal>
        <p class="eyebrow">Was Besucher über die AI Nights sagen</p>
        <h2 class="display-font sec-h">Stimmen aus der Community</h2>
        <div class="testi-videos">
          {['ALEX', 'BERND', 'ROLAND'].map((n) => (
            <video controls preload="metadata" playsinline>
              <source type="video/mp4" src={`/wp-content/uploads/2026/02/${n}-AINIGHTS-TESTIMONIAL.mp4`} />
            </video>
          ))}
        </div>
        <div class="testi-grid">
          {testimonials.map((q) => (
            <blockquote class="testi card"><p>„{q}"</p></blockquote>
          ))}
        </div>
      </section>

      {/* Moderation */}
      {moderators.length > 0 && (
        <section class="sec" data-reveal>
          <p class="eyebrow">Wer dich durch den Abend führt</p>
          <h2 class="display-font sec-h">Moderation</h2>
          <div class="speaker-list">
            {moderators.map((s) => (
              <a href={`/speaker/${s.data.slug}/`} class="speaker-full card moderator-card">
                {s.data.image?.src && <img class="sp-photo" src={imgVariant(s.data.image.src, 400)} alt={s.data.title} loading="lazy" />}
                <div class="sp-body">
                  <h3>{s.data.title}</h3>
                  {s.data.jobTitle && <p class="sp-role">{s.data.jobTitle}</p>}
                  {s.data.excerpt && <p class="sp-bio">{s.data.excerpt}</p>}
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      {/* Speaker-Vorstellung */}
