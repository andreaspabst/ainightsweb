      linear-gradient(135deg, rgba(255, 45, 122, 0.14), rgba(50, 107, 255, 0.1)),
      var(--bg-glass);
    backdrop-filter: blur(12px);
  }
  .facts-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(50px);
    pointer-events: none;
    opacity: 0.5;
  }
  .facts-orb-a {
    width: 220px;
    height: 220px;
    top: -80px;
    left: -60px;
    background: radial-gradient(circle, rgba(255, 45, 122, 0.6), transparent 70%);
  }
  .facts-orb-b {
    width: 220px;
    height: 220px;
    bottom: -100px;
    right: -60px;
    background: radial-gradient(circle, rgba(50, 107, 255, 0.55), transparent 70%);
  }
  .facts h2 {
    position: relative;
    font-size: 1.7rem;
    margin-bottom: 1.6rem;
    text-align: center;
  }
  .facts ul {
    position: relative;
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.1rem;
  }
  .facts li {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    color: var(--text-secondary);
    font-size: 1.02rem;
  }
  .fact-icon {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    flex-shrink: 0;
    border-radius: 50%;
    font-size: 1.2rem;
  }
  .fact-icon-a {
    background: rgba(255, 45, 122, 0.16);
    border: 1px solid rgba(255, 45, 122, 0.35);
  }
  .fact-icon-b {
    background: rgba(50, 107, 255, 0.16);
    border: 1px solid rgba(50, 107, 255, 0.35);
  }
  .facts-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(200px, 320px) 1fr;
    gap: 2.2rem;
    align-items: center;
  }
  .facts-img {
    aspect-ratio: 4 / 5;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .facts-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .facts-info h2 {
    text-align: left;
  }
  .facts-cta {
    margin-top: 1.8rem;
  }
  @media (max-width: 720px) {
    .facts-cta {
      display: flex;
      justify-content: center;
    }
    .facts-grid {
      grid-template-columns: 1fr;
    }
    .facts-img {
      aspect-ratio: 16 / 9;
      max-width: 320px;
      margin-inline: auto;
    }
    .facts-info h2 {
      text-align: center;
    }
  }
  .sec {
    position: relative;
    margin-bottom: 5.5rem;
  }
  .sec::before {
    content: '';
    position: absolute;
    z-index: -1;
    top: -2.5rem;
    left: 50%;
    width: 640px;
    max-width: 130vw;
    height: 380px;
    transform: translateX(-50%);
    background: radial-gradient(ellipse at center, rgba(255, 45, 122, 0.07), transparent 70%);
    pointer-events: none;
  }
  .sec:nth-of-type(even)::before {
    background: radial-gradient(ellipse at center, rgba(50, 107, 255, 0.07), transparent 70%);
  }
  .sec > .eyebrow {
    display: block;
    text-align: center;
    font-size: 0.92rem;
  }
  .sec-h {
    font-size: clamp(1.8rem, 4.5vw, 2.6rem);
    margin: 0.4rem 0 1.8rem;
    text-align: center;
  }

  /* Speaker & Moderation — vollständige Vorstellung */
  .speaker-list {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }
  .speaker-full {
    display: flex;
    gap: 2rem;
    padding: 2rem;
    align-items: flex-start;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .moderator-card {
    align-items: center;
  }
  a.speaker-full:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }
  .sp-photo-link {
    flex-shrink: 0;
  }
  .sp-photo {
    display: block;
    width: 168px;
    height: 168px;
    border-radius: 20px;
    object-fit: cover;
    flex-shrink: 0;
  }
  .sp-photo-fallback {
    display: grid;
    place-items: center;
    background: var(--gradient-accent);
    font-size: 2.6rem;
  }
  .sp-body h3 {
    font-size: 1.4rem;
    margin-bottom: 0.35rem;
  }
  .sp-body h3 a {
    color: var(--text-primary);
  }
  .sp-body h3 a:hover {
    color: var(--magenta-bright);
  }
  .sp-role {
    color: var(--blue-bright);
    font-weight: 600;
    font-size: 0.98rem;
    margin: 0 0 0.9rem;
  }
  .sp-bio {
    color: var(--text-secondary);
    font-size: 1.02rem;
    line-height: 1.7;
    margin-bottom: 0.8rem;
  }
  .sp-topics {
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .sp-topics li {
    padding-left: 1.5rem;
    position: relative;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
  .sp-topics li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--magenta-bright);
  }
  .sp-social {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--blue-bright);
  }
  .speaker-full.tba {
    opacity: 0.75;
    align-items: center;
  }
  .speaker-full.tba .sp-photo {
    width: 96px;
    height: 96px;
    border-radius: 50%;
  }

  /* Programm als Kachel-Stack: jede Karte bleibt beim Scrollen kurz „kleben“,
     bis die nächste Karte sich darüberschiebt — dadurch entsteht beim
     Hoch-/Runterscrollen ein überlappender, bewegter Kartenstapel-Effekt. */
  .stack {
    position: relative;
    padding-bottom: 1.5rem;
  }
  .stack-card {
    position: sticky;
    top: calc(84px + var(--i, 0) * 18px);
    margin-bottom: 1.4rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-top: 3px solid var(--border-strong);
    border-radius: calc(var(--radius) + 6px);
    padding: 2rem 2.2rem;
    box-shadow: 0 24px 48px -16px rgba(0, 0, 0, 0.6);
    z-index: calc(var(--i, 0) + 1);
  }
  .stack-card:nth-child(odd) {
    background-color: var(--bg-elevated);
    background-image: linear-gradient(160deg, rgba(255, 45, 122, 0.16), transparent 60%);
    border-top-color: var(--magenta-bright);
  }
  .stack-card:nth-child(even) {
    background-color: var(--bg-elevated);
    background-image: linear-gradient(160deg, rgba(50, 107, 255, 0.16), transparent 60%);
    border-top-color: var(--blue-bright);
  }
  .stack-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin: 0.4rem 0 0.9rem;
  }
  .stack-time {
    color: var(--text-primary);
    font-weight: 700;
    font-size: 0.95rem;
    margin-right: 0.3rem;
  }
  .stack-card h3 {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }
  .chip {
    display: inline-block;
    background: var(--bg-base);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.2rem 0.75rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }
  /* Einlass- & Pausen-Hinweise: eigener, farblich bewegter Block statt unauffälliger Pille */
  .stack-note,
  .stack-card.stack-break {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.6rem;
    margin-bottom: 1.4rem;
    border-radius: calc(var(--radius) + 6px);
    border: 1px solid var(--border-strong);
    background-color: var(--bg-elevated);
    background-image: linear-gradient(120deg, rgba(255, 45, 122, 0.35), rgba(50, 107, 255, 0.35), rgba(255, 45, 122, 0.35));
    background-size: 220% 220%;
    animation: note-flow 7s ease infinite;
    box-shadow: none;
  }
  @keyframes note-flow {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .stack-note,
    .stack-card.stack-break {
      animation: none;
    }
  }
  .note-pill {
    color: var(--text-primary);
    font-size: 0.95rem;
    font-weight: 700;
  }
  .talk-sp {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 0.9rem;
  }
  .talk-sp-avatars {
    display: inline-flex;
    flex-shrink: 0;
  }
  .talk-sp-avatars img,
  .talk-sp-fallback {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--bg-elevated);
    margin-left: -10px;
    display: grid;
    place-items: center;
    background: var(--gradient-accent);
    font-size: 0.85rem;
  }
  .talk-sp-avatars img:first-child,
  .talk-sp-fallback:first-child {
    margin-left: 0;
  }
  .talk-sp-names {
    color: var(--blue-bright);
    font-size: 0.9rem;
    font-weight: 600;
  }
  .talk-ex {
    color: var(--text-secondary);
    font-size: 1rem;
    margin-bottom: 0.8rem;
  }
  .talk-detail {
    margin: 0.4rem 0 0.9rem;
  }
  .talk-detail summary {
    cursor: pointer;
    color: var(--magenta-bright);
    font-size: 0.92rem;
    font-weight: 600;
    list-style: none;
  }
  .talk-detail summary::-webkit-details-marker {
    display: none;
  }
  .talk-detail[open] summary {
    margin-bottom: 0.8rem;
  }
  .talk-detail .prose {
    font-size: 0.98rem;
  }
  .photos-note {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.95rem;
    margin: -0.8rem 0 1.6rem;
  }
  .photos {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 0.8rem;
  }
  .photo {
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .photo:hover img {
    transform: scale(1.05);
  }
  .gal-link {
    margin-top: 1.5rem;
  }
  .testi-videos {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .testi-videos video {
    width: 100%;
    border-radius: var(--radius, 12px);
    border: 1px solid var(--border);
    background: #000;
    display: block;
  }
  .testi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }
  .testi {
    padding: 1.8rem;
    margin: 0;
  }
  .testi p {
    color: var(--text-primary);
    font-style: italic;
    font-size: 1.02rem;
  }
  .sponsor-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .sponsor-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.6rem 2.1rem;
    min-width: 190px;
    min-height: 110px;
  }
  .sponsor-logo:hover {
    border-color: var(--border-strong);
  }
  .sponsor-logo img {
    max-height: 64px;
    max-width: 170px;
    object-fit: contain;
  }

  /* YouTube-Einblick */
  .yt-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: #000;
  }
  .yt-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* Gastgeber — eigenständiges, farbig abgesetztes Panel (bricht aus dem 980px-Container aus) */
  .host-sec {
    margin-bottom: 0;
  }
  .host-panel {
    position: relative;
    width: 100vw;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    overflow: hidden;
    padding-block: clamp(3.5rem, 8vw, 6rem);
    background:
      radial-gradient(ellipse 60% 80% at 15% 20%, rgba(255, 45, 122, 0.16), transparent 60%),
      radial-gradient(ellipse 60% 80% at 85% 80%, rgba(50, 107, 255, 0.16), transparent 60%),
      var(--bg-elevated);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .host-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    pointer-events: none;
    opacity: 0.5;
  }
  .host-orb-a {
    width: 320px;
    height: 320px;
    top: -100px;
    left: 8%;
    background: radial-gradient(circle, rgba(255, 45, 122, 0.5), transparent 70%);
  }
  .host-orb-b {
    width: 300px;
    height: 300px;
    bottom: -120px;
    right: 10%;
    background: radial-gradient(circle, rgba(50, 107, 255, 0.45), transparent 70%);
  }
  .host-inner {
    position: relative;
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: 1.5rem;
    display: grid;
    grid-template-columns: minmax(200px, 260px) 1fr;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: center;
  }
  .host-photo-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .host-photo-ring {
    width: 100%;
    max-width: 240px;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    padding: 5px;
    background: var(--gradient-accent);
    background-size: 200% 200%;
    box-shadow: var(--glow-magenta);
    animation: host-ring-wobble 5s ease-in-out infinite;
  }
  @keyframes host-ring-wobble {
    0%, 100% { background-position: 0% 50%; filter: hue-rotate(0deg); }
    50% { background-position: 100% 50%; filter: hue-rotate(20deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .host-photo-ring { animation: none; }
  }
  .host-photo-ring img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--bg-elevated);
    display: block;
  }
  .host-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: var(--bg-glass);
    border: 1px solid var(--border-strong);
    backdrop-filter: blur(12px);
    border-radius: 999px;
    padding: 0.35rem 0.9rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-secondary);
  }
  .host-eyebrow {
    color: var(--blue-bright);
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.6rem;
  }
  .host-name {
    font-size: clamp(1.9rem, 4.5vw, 2.6rem);
    margin: 0 0 0.3rem;
  }
  .host-role {
    color: var(--magenta-bright);
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: 1.2rem;
  }
  .host-prose p {
    margin: 0 0 1rem;
  }
  .host-body .btn {
    margin-top: 0.6rem;
  }
  @media (max-width: 760px) {
    .host-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .host-eyebrow,
    .host-role {
      text-align: center;
    }
  }

  /* Parallax-Zitate — bricht aus dem 980px-Container aus, Duoton-Foto + Marquee */
  .quote-parallax {
    position: relative;
    width: 100vw;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    overflow: hidden;
    padding: 0;
  }
  .qp-bg {
    position: absolute;
    inset: -15% 0;
    background-size: cover;
    background-position: center;
    will-change: transform;
  }
  .qp-duotone {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(220, 39, 119, 0.65), rgba(50, 107, 255, 0.55));
    mix-blend-mode: color;
    opacity: 0.22;
  }
  .qp-stars {
    position: absolute;
    inset: -15% 0;
    background-image:
      radial-gradient(1.4px 1.4px at 20% 30%, rgba(255, 255, 255, 0.9), transparent),
      radial-gradient(1px 1px at 65% 12%, rgba(255, 255, 255, 0.7), transparent),
      radial-gradient(1.6px 1.6px at 82% 40%, rgba(255, 255, 255, 0.85), transparent),
      radial-gradient(1px 1px at 35% 65%, rgba(255, 255, 255, 0.6), transparent),
      radial-gradient(1.2px 1.2px at 92% 78%, rgba(255, 255, 255, 0.8), transparent),
      radial-gradient(1px 1px at 8% 85%, rgba(255, 255, 255, 0.6), transparent);
    background-repeat: repeat;
    background-size: 300px 300px;
    animation: twinkle 5s ease-in-out infinite alternate;
    pointer-events: none;
  }
  .qp-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10, 1, 24, 0.45), rgba(10, 1, 24, 0.88) 75%, var(--bg-base) 100%);
  }
  .qp-inner {
    position: relative;
    max-width: 800px;
    margin-inline: auto;
    padding: clamp(4.5rem, 10vw, 7rem) 1.5rem 0;
    text-align: center;
  }
  .qp-mark {
    display: block;
    font-family: 'Space Grotesk', serif;
    font-size: clamp(4rem, 10vw, 6rem);
    line-height: 1;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: -0.8rem;
  }
  .qp-lead {
    font-size: clamp(1.15rem, 2.4vw, 1.5rem);
    color: var(--text-primary);
    line-height: 1.6;
    font-weight: 600;
    margin: 0 0 1rem;
  }
  .qp-marquee {
    position: relative;
    margin-top: 3rem;
    padding-bottom: clamp(3rem, 7vw, 5rem);
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .qp-track {
    display: flex;
    width: max-content;
    animation: qp-scroll 28s linear infinite;
  }
  .qp-marquee:hover .qp-track {
    animation-play-state: paused;
  }
  .qp-track-set {
    display: flex;
    gap: 1.2rem;
    padding-inline: 0.6rem;
  }
  @keyframes qp-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .qp-track {
      animation: none;
      width: auto;
      flex-wrap: wrap;
      justify-content: center;
      max-width: var(--maxw);
      margin-inline: auto;
    }
    .qp-track-set {
      flex-wrap: wrap;
      justify-content: center;
    }
    .qp-track-set:last-child {
      display: none;
    }
  }
  .qp-quote {
    flex: 0 0 auto;
    width: min(300px, 78vw);
    background: rgba(20, 10, 42, 0.82);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.4rem;
    margin: 0;
  }
  .qp-quote p {
    color: var(--text-primary);
    font-style: italic;
    font-size: 0.95rem;
    margin: 0;
    text-align: left;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .faq-item {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .faq-item summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.2rem 1.6rem;
    font-weight: 600;
    color: var(--text-primary);
    font-size: 1rem;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-icon {
    flex-shrink: 0;
    color: var(--magenta-bright);
    font-size: 1.3rem;
    transition: transform 0.2s ease;
  }
  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
  }
  .faq-item p {
    padding: 0 1.6rem 1.4rem;
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.96rem;
    line-height: 1.7;
    white-space: pre-line;
  }

  /* Für wen — Zielgruppen-Karten */
  .audience-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.2rem;
  }
  .audience-card {
    position: relative;
    padding: 1.8rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background-color: var(--bg-elevated);
    background-image: radial-gradient(ellipse at top left, rgba(255, 45, 122, 0.14), transparent 60%);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  .audience-card:nth-child(2) {
    background-image: radial-gradient(ellipse at top left, rgba(50, 107, 255, 0.14), transparent 60%);
