---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import galleryData from '../../data/gallery.json';
import { isPlaceholderSpeaker } from '../../lib/speakers';
import { imgVariant } from '../../lib/images';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((e) => ({ params: { slug: e.data.slug }, props: { e } }));
}

const { e } = Astro.props;
const d = e.data;

// Foto-Rückblick dieses Events (falls vorhanden)
const galleryGroup = (galleryData as { event: string; images: string[] }[]).find((g) => g.event === d.slug);
const eventPhotos = galleryGroup?.images.slice(0, 24) ?? [];

// Community-Stimmen (wie auf der Startseite)
const testimonials = [
  'Sehr unterhaltsam und fachlich stark. Man merkt, dass hier echte Erfahrung auf der Bühne steht.',
  'Lockere Atmosphäre, starke Location und interessante Vorträge. Man fühlt sich sofort abgeholt und willkommen.',
  'Die Mischung aus Vortrags-Diversität und Live-Demos war top. Abwechslungsreich und nie langweilig.',
];

// Beziehungen (Post-IDs) zu Collection-Einträgen auflösen
const speakerColl = await getCollection('speaker');
const sessionColl = await getCollection('sessions');
const sponsorColl = await getCollection('sponsor');
const byId = (coll: any[]) => new Map(coll.filter((x) => x.data.id).map((x) => [x.data.id, x]));
const spMap = byId(speakerColl);
const seMap = byId(sessionColl);
const spoMap = byId(sponsorColl);

const resolve = (ids: number[] | undefined, m: Map<number, any>) =>
  (ids ?? []).map((id) => m.get(id)).filter(Boolean);

const speakerSlots = resolve(d.speakerIds, spMap);
const speakers = speakerSlots.filter((s) => !isPlaceholderSpeaker(s));
// Noch unbesetzte Slots (Platzhalter) als „Wird noch bekanntgegeben“ zeigen
const tbaCount = speakerSlots.length - speakers.length;
const moderators = resolve(d.moderatorIds, spMap);
// Komplettes Programm inkl. Pausen — wie im Original; Pausen werden schlanker dargestellt
const sessions = resolve(d.sessionIds, seMap);
const isBreak = (s: any) => /pause|break/i.test(s.data.title);
const sponsors = resolve(d.sponsorIds, spoMap);

// Meta-Badges einer Session (Bühne, Level) — Zeit/Dauer wandern in die Timeline-Spalte
function sessionMeta(s: any) {
  const m: string[] = [];
  if (s.data.room) m.push(s.data.room);
  if (s.data.level) m.push(String(s.data.level).charAt(0).toUpperCase() + String(s.data.level).slice(1));
  return m;
}

// Hero-Hintergrund: echtes Eventfoto statt des Branding-Bilds (das enthält
// eingebrannten Titeltext und kollidiert sonst mit der H1). Fallback: Publikumsfoto.
const heroBg = eventPhotos[0] ?? '/wp-content/uploads/2026/01/1-34-publikum.jpg';

function fmtDate(dt?: string) {
  if (!dt) return null;
  const p = new Date(dt);
  if (isNaN(p.getTime())) return dt;
  return p.toLocaleDateString('de-DE', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' });
}
const dateLabel = fmtDate(d.eventDate);
const isPast = d.eventDate ? new Date(d.eventDate) < new Date('2026-07-14') : false;
const countdownTarget = !isPast && d.eventDate ? `${d.eventDate}T${d.startTime ?? '18:00'}:00` : null;

const facts: { icon: string; label: string }[] = [
  { icon: '🎤', label: `${speakerSlots.length || 3} Speaker${moderators.length ? ' & ' + moderators.length + ' Moderator' : ''}` },
  { icon: '🤖', label: '100% KI-Fokus' },
  { icon: '🗂️', label: sessions.length ? `${sessions.length} Sessions` : 'Kurze Impuls-Sessions' },
  { icon: '💬', label: 'Zeit für Gespräche & Austausch' },
  { icon: '🥂', label: 'Inklusive Drinks & Snacks' },
];
---

<Layout
  lang="de"
  title={d.seo?.title ?? `${d.title} — AI Nights`}
  description={d.seo?.description ?? d.excerpt ?? `${d.title} — ein AI Nights Afterwork-Event${d.city ? ` in ${d.city}` : ''}.`}
  path={`/events/${d.slug}/`}
  image={d.image?.src}
  ogType="event"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Event',
    name: d.title,
    startDate: d.eventDate,
    eventStatus: 'https://schema.org/EventScheduled',
    eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
    location: d.locationName
      ? { '@type': 'Place', name: d.locationName, address: d.locationAddress ?? d.city }
      : undefined,
    image: d.image?.src ? `https://ainights.ai${d.image.src}` : undefined,
    description: d.excerpt,
    performer: speakers.map((s) => ({ '@type': 'Person', name: s.data.title })),
    organizer: { '@type': 'Organization', name: 'AI Nights', url: 'https://ainights.ai' },
  }}
>
  <Header lang="de" />
  <main>
    <section class="hero">
      <img class="hero-bg" src={imgVariant(heroBg, 1600)} alt="" role="presentation" />
      <div class="hero-overlay"></div>
      <div class="hero-stars"></div>
      <div class="hero-orb hero-orb-a"></div>
      <div class="hero-orb hero-orb-b"></div>
      <div class="container hero-inner">
        <a href="/events/" class="back">← Alle Events</a>
        <div class="badges">
          {d.city && <span class="badge">{d.city}</span>}
          {isPast && <span class="badge past">Vergangenes Event</span>}
        </div>
        <p class="kicker">Afterwork Event{dateLabel ? ` am ${new Date(d.eventDate!).toLocaleDateString('de-DE')}` : ''}</p>
        <h1 class="display-font">{d.title}</h1>

        {(d.contentHtml || d.excerpt) && (
          <div class="hero-desc prose">
            {d.contentHtml ? <div set:html={d.contentHtml} /> : <p>{d.excerpt}</p>}
          </div>
        )}

        <div class="meta">
          {dateLabel && <span>📅 {dateLabel}</span>}
          {d.startTime && <span>🕕 {d.startTime} Uhr</span>}
          {d.locationName && <span>📍 {d.locationName}</span>}
        </div>

        {speakers.length > 0 && (
          <a href="#lineup" class="hero-speakers">
            <span class="hero-speakers-avatars">
              {[...moderators, ...speakers].slice(0, 5).map((s) => (
                s.data.image?.src
                  ? <img src={imgVariant(s.data.image.src, 96)} alt="" loading="lazy" />
                  : <span class="hero-speakers-fallback">✨</span>
              ))}
            </span>
            <span>Speakerauswahl des Abends ansehen ↓</span>
          </a>
        )}

        <div class="hero-actions">
          {d.ticketUrl && !isPast && <a href={d.ticketUrl} class="btn btn-primary">Tickets sichern</a>}

          {countdownTarget && (
            <div class="countdown" data-countdown={countdownTarget}>
              <div class="cd-box"><strong data-cd-d>00</strong><span>Tage</span></div>
              <div class="cd-sep">:</div>
              <div class="cd-box"><strong data-cd-h>00</strong><span>Std</span></div>
              <div class="cd-sep">:</div>
              <div class="cd-box"><strong data-cd-m>00</strong><span>Min</span></div>
              <div class="cd-sep">:</div>
              <div class="cd-box"><strong data-cd-s>00</strong><span>Sek</span></div>
            </div>
          )}
        </div>
      </div>
    </section>

    <div class="container body">
      {/* Fakten */}
      <section class="facts card" data-reveal>
        <h2 class="display-font">Das Afterwork-Event in Kürze</h2>
        <ul>
          {facts.map((f) => (
            <li>
              <span class="fact-icon">{f.icon}</span>
              <span>{f.label}</span>
            </li>
          ))}
        </ul>
      </section>

      {/* Programm */}
      {sessions.length > 0 && (
        <section class="sec" data-reveal>
          <p class="eyebrow">Gespräche. Impulse. Perspektiven.</p>
          <h2 class="display-font sec-h">Die Themen des Abends</h2>
          <div class="timeline">
            {sessions.map((s) => {
              const sp = (s.data.speakerIds ?? [])
                .map((id: number) => spMap.get(id))
                .filter(Boolean)
                .filter((x: any) => !isPlaceholderSpeaker(x));
              const meta = sessionMeta(s);
              if (isBreak(s)) {
                return (
                  <div class="tl-item tl-break">
                    <div class="tl-time">
                      {s.data.startTime && <span class="tt-time">{s.data.startTime}</span>}
                    </div>
                    <div class="tl-dot tl-dot-break"></div>
                    <div class="tl-content break-content">
                      <span class="break-pill">☕ {s.data.title}{s.data.duration && ` · ${s.data.duration} min`}</span>
                    </div>
                  </div>
                );
              }
              return (
                <div class="tl-item">
                  <div class="tl-time">
                    {s.data.startTime && <span class="tt-time">{s.data.startTime}</span>}
                    {s.data.duration && <span class="tt-dur">{s.data.duration} min</span>}
                  </div>
                  <div class="tl-dot"></div>
                  <article class="tl-content card">
                    {meta.length > 0 && (
                      <p class="talk-meta">
                        {meta.map((m) => <span class="chip">{m}</span>)}
                      </p>
                    )}
                    <h3>{s.data.title}</h3>
                    {sp.length > 0 && (
                      <div class="talk-sp">
                        <span class="talk-sp-avatars">
                          {sp.map((x: any) => (
                            x.data.image?.src
                              ? <img src={imgVariant(x.data.image.src, 80)} alt="" loading="lazy" />
                              : <span class="talk-sp-fallback">✨</span>
                          ))}
                        </span>
                        <span class="talk-sp-names">{sp.map((x: any) => x.data.title).join(', ')}</span>
                      </div>
                    )}
                    {s.data.excerpt && <p class="talk-ex">{s.data.excerpt}</p>}
                    {s.data.contentHtml && s.data.contentHtml.replace(/<[^>]+>/g, '').trim().length > (s.data.excerpt?.length ?? 0) + 20 && (
                      <details class="talk-detail">
                        <summary>Mehr anzeigen</summary>
                        <div class="prose" set:html={s.data.contentHtml} />
                      </details>
                    )}
                  </article>
                </div>
              );
            })}
          </div>
        </section>
      )}

      {/* Speaker-Vorstellung */}
      {(speakers.length > 0 || tbaCount > 0) && (
        <section class="sec" id="lineup" data-reveal>
          <p class="eyebrow">Lerne von Branchenexperten und Vordenkern</p>
          <h2 class="display-font sec-h">Speaker des Abends</h2>
          <div class="speaker-list">
            {speakers.map((s) => (
              <div class="speaker-full card">
                <a href={`/speaker/${s.data.slug}/`} class="sp-photo-link">
                  {s.data.image?.src
                    ? <img class="sp-photo" src={imgVariant(s.data.image.src, 400)} alt={s.data.title} loading="lazy" />
                    : <span class="sp-photo sp-photo-fallback">✨</span>}
                </a>
                <div class="sp-body">
                  <h3><a href={`/speaker/${s.data.slug}/`}>{s.data.title}</a></h3>
                  {s.data.jobTitle && <p class="sp-role">{s.data.jobTitle}</p>}
                  {s.data.bioHtml
                    ? <div class="sp-bio prose" set:html={s.data.bioHtml} />
                    : s.data.excerpt && <p class="sp-bio">{s.data.excerpt}</p>}
                  {s.data.topics?.length > 0 && (
                    <ul class="sp-topics">
                      {s.data.topics.map((t: string) => <li>{t}</li>)}
                    </ul>
                  )}
                  {s.data.socials?.linkedin && (
                    <a href={s.data.socials.linkedin} target="_blank" rel="noopener" class="sp-social">LinkedIn ↗</a>
                  )}
                </div>
              </div>
            ))}
            {Array.from({ length: tbaCount }).map(() => (
              <div class="speaker-full card tba">
                <span class="sp-photo sp-photo-fallback">✨</span>
                <div class="sp-body">
                  <h3>Wird noch bekanntgegeben</h3>
                  <p class="sp-role">Speaker folgt in Kürze</p>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {/* Moderation */}
      {moderators.length > 0 && (
        <section class="sec" data-reveal>
          <p class="eyebrow">Wer dich durch den Abend führt</p>
          <h2 class="display-font sec-h">Moderation</h2>
          <div class="speaker-list">
            {moderators.map((s) => (
              <a href={`/speaker/${s.data.slug}/`} class="speaker-full card moderator-card">
                {s.data.image?.src && <img class="sp-photo" src={imgVariant(s.data.image.src, 400)} alt={s.data.title} loading="lazy" />}
                <div class="sp-body">
                  <h3>{s.data.title}</h3>
                  {s.data.jobTitle && <p class="sp-role">{s.data.jobTitle}</p>}
                  {s.data.excerpt && <p class="sp-bio">{s.data.excerpt}</p>}
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      {/* Sponsoren */}
      {sponsors.length > 0 && (
        <section class="sec" data-reveal>
          <p class="eyebrow">Möglich gemacht von</p>
          <h2 class="display-font sec-h">Sponsoren dieses Events</h2>
          <div class="sponsor-row">
            {sponsors.map((s) => (
              <a href={`/sponsor/${s.data.slug}/`} class="sponsor-logo card" title={s.data.title}>
                <img src={s.data.logo?.src ?? s.data.image?.src} alt={s.data.title} loading="lazy" />
              </a>
            ))}
          </div>
        </section>
      )}

      {/* Foto-Rückblick vergangener Events */}
      {eventPhotos.length > 0 && (
        <section class="sec" data-reveal>
          <p class="eyebrow">AI Nights Rückblick</p>
          <h2 class="display-font sec-h">Impressionen von diesem Event</h2>
          <div class="photos">
            {eventPhotos.map((src) => (
              <a href={src} target="_blank" rel="noopener" class="photo">
                <img src={imgVariant(src, 320)} alt={`Impression ${d.title}`} loading="lazy" />
              </a>
            ))}
          </div>
          <a href="/de/galerie/" class="btn btn-ghost gal-link">Zur ganzen Galerie</a>
        </section>
      )}

      {/* Stimmen aus der Community — Video-Testimonials wie im Original */}
      <section class="sec" data-reveal>
        <p class="eyebrow">Was Besucher über die AI Nights sagen</p>
        <h2 class="display-font sec-h">Stimmen aus der Community</h2>
        <div class="testi-videos">
          {['ALEX', 'BERND', 'ROLAND'].map((n) => (
            <video controls preload="metadata" playsinline>
              <source type="video/mp4" src={`/wp-content/uploads/2026/02/${n}-AINIGHTS-TESTIMONIAL.mp4`} />
            </video>
          ))}
        </div>
        <div class="testi-grid">
          {testimonials.map((q) => (
            <blockquote class="testi card"><p>„{q}"</p></blockquote>
          ))}
        </div>
      </section>

      <section class="cta card" data-reveal>
        <div class="cta-glow"></div>
        <h2 class="display-font">{isPast ? 'Beim nächsten AI Nights Afterwork dabei sein' : 'Sichere dir deinen Platz'}</h2>
        <a href={!isPast && d.ticketUrl ? d.ticketUrl : '/de/tickets/'} class="btn btn-primary">
          {isPast ? 'Kommende Events ansehen' : 'Tickets sichern'}
        </a>
      </section>
    </div>
  </main>
  <Footer lang="de" />
</Layout>

<script>
  function initCountdowns() {
    document.querySelectorAll<HTMLElement>('[data-countdown]').forEach((el) => {
      const target = new Date(el.dataset.countdown ?? '').getTime();
      if (Number.isNaN(target)) return;
      const dEl = el.querySelector('[data-cd-d]');
      const hEl = el.querySelector('[data-cd-h]');
      const mEl = el.querySelector('[data-cd-m]');
      const sEl = el.querySelector('[data-cd-s]');
      let timer: ReturnType<typeof setInterval>;
      function tick() {
        const diff = Math.max(0, target - Date.now());
        const days = Math.floor(diff / 86400000);
        const hours = Math.floor((diff % 86400000) / 3600000);
        const mins = Math.floor((diff % 3600000) / 60000);
        const secs = Math.floor((diff % 60000) / 1000);
        if (dEl) dEl.textContent = String(days).padStart(2, '0');
        if (hEl) hEl.textContent = String(hours).padStart(2, '0');
        if (mEl) mEl.textContent = String(mins).padStart(2, '0');
        if (sEl) sEl.textContent = String(secs).padStart(2, '0');
        if (diff <= 0) clearInterval(timer);
      }
      tick();
      timer = setInterval(tick, 1000);
    });
  }

  function initReveal() {
    const els = document.querySelectorAll<HTMLElement>('[data-reveal]');
    if (!('IntersectionObserver' in window)) {
      els.forEach((el) => el.classList.add('is-visible'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -60px 0px' }
    );
    els.forEach((el) => io.observe(el));
  }

  initCountdowns();
  initReveal();
</script>

<style>
  .hero {
    position: relative;
    padding-block: clamp(4rem, 11vw, 7.5rem) clamp(3.5rem, 8vw, 6rem);
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.34;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10, 1, 24, 0.45), var(--bg-base) 92%);
  }
  .hero-stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1.4px 1.4px at 20% 30%, rgba(255, 255, 255, 0.9), transparent),
      radial-gradient(1px 1px at 65% 12%, rgba(255, 255, 255, 0.7), transparent),
      radial-gradient(1.6px 1.6px at 82% 40%, rgba(255, 255, 255, 0.85), transparent),
      radial-gradient(1px 1px at 35% 65%, rgba(255, 255, 255, 0.6), transparent),
      radial-gradient(1.2px 1.2px at 92% 78%, rgba(255, 255, 255, 0.8), transparent),
      radial-gradient(1px 1px at 8% 85%, rgba(255, 255, 255, 0.6), transparent),
      radial-gradient(1.3px 1.3px at 50% 90%, rgba(255, 255, 255, 0.7), transparent),
      radial-gradient(1px 1px at 55% 45%, rgba(255, 255, 255, 0.5), transparent);
    background-repeat: repeat;
    background-size: 340px 340px;
    animation: twinkle 5s ease-in-out infinite alternate;
    pointer-events: none;
  }
  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
    opacity: 0.55;
  }
  .hero-orb-a {
    width: 420px;
    height: 420px;
    top: -140px;
    right: -100px;
    background: radial-gradient(circle, rgba(255, 45, 122, 0.55), transparent 70%);
    animation: drift-a 16s ease-in-out infinite alternate;
  }
  .hero-orb-b {
    width: 360px;
    height: 360px;
    bottom: -160px;
    left: -80px;
    background: radial-gradient(circle, rgba(50, 107, 255, 0.45), transparent 70%);
    animation: drift-b 20s ease-in-out infinite alternate;
  }
  @keyframes twinkle {
    from { opacity: 0.55; }
    to { opacity: 1; }
  }
  @keyframes drift-a {
    from { transform: translate(0, 0); }
    to { transform: translate(-40px, 30px); }
  }
  @keyframes drift-b {
    from { transform: translate(0, 0); }
    to { transform: translate(30px, -30px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-stars,
    .hero-orb-a,
    .hero-orb-b {
      animation: none;
    }
  }
  .hero-inner {
    position: relative;
    text-align: center;
  }
  .back {
    display: inline-block;
    color: var(--text-secondary);
    font-size: 0.9rem;
    text-align: left;
  }
  .badges {
    display: flex;
    justify-content: center;
    gap: 0.6rem;
    margin: 1.8rem 0 1.2rem;
  }
  .badge {
    background: var(--gradient-accent);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
  }
  .badge.past {
    background: var(--bg-glass);
    border: 1px solid var(--border);
    color: var(--text-muted);
  }
  .kicker {
    color: var(--blue-bright);
    font-weight: 600;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.8rem;
  }
  h1 {
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    line-height: 1.08;
    max-width: 22ch;
    margin: 0 auto 1.6rem;
  }
  .hero-desc {
    max-width: 680px;
    margin: 0 auto 1.8rem;
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.75;
  }
  .hero-desc :global(p) {
    margin: 0 0 1rem;
  }
  .hero-desc :global(ul),
  .hero-desc :global(ol) {
    text-align: left;
    display: inline-block;
    margin: 1rem auto;
    padding-left: 1.3rem;
  }
  .hero-desc :global(strong) {
    color: var(--text-primary);
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.4rem;
    color: var(--text-secondary);
    font-size: 1.02rem;
    margin-bottom: 1.8rem;
  }
  .hero-speakers {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    color: var(--text-secondary);
    font-size: 0.92rem;
    font-weight: 600;
    margin-bottom: 2.2rem;
    transition: color 0.2s ease;
  }
  .hero-speakers:hover {
    color: var(--text-primary);
  }
  .hero-speakers-avatars {
    display: inline-flex;
  }
  .hero-speakers-avatars img,
  .hero-speakers-fallback {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--bg-base);
    margin-left: -12px;
    display: grid;
    place-items: center;
    background: var(--gradient-accent);
    font-size: 1.1rem;
  }
  .hero-speakers-avatars img:first-child,
  .hero-speakers-fallback:first-child {
    margin-left: 0;
  }
  .hero-actions {
    display: flex;
    flex-direction: column;
