---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SponsorTiers from '../../components/SponsorTiers.astro';
---

<Layout
  lang="en"
  title="Our Sponsors — AI Nights"
  description="Meet the companies that make the AI Nights possible – from Platinum to Bronze sponsors."
  path="/en/our-sponsors/"
  alternates={{ de: '/de/sponsors/', en: '/en/our-sponsors/' }}
>
  <Header lang="en" />
  <main class="container section">
    <div class="head">
      <p class="eyebrow">Thanks to our partners</p>
      <h1 class="display-font">Our Sponsors</h1>
      <p class="sub">The fantastic companies that make AI&nbsp;Nights possible.</p>
    </div>
    <SponsorTiers lang="en" />
    <div class="cta">
      <p>Want to support the AI&nbsp;Nights?</p>
      <a href="/en/become-sponsor/" class="btn btn-primary">Become a sponsor</a>
    </div>
  </main>
  <Footer lang="en" />
</Layout>

<style>
  .head {
    text-align: center;
    margin-bottom: 3rem;
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin: 0.4rem 0 0.6rem;
  }
  .sub {
    color: var(--text-secondary);
    font-size: 1.05rem;
  }
  .cta {
    text-align: center;
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }
  .cta p {
    color: var(--text-secondary);
  }
</style>
