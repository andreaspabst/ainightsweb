---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const items = await getCollection('assistants');
  return items.map((a) => ({ params: { slug: a.data.slug }, props: { a } }));
}

const { a } = Astro.props;
const d = a.data;
---

<Layout
  lang="de"
  title={d.seo?.title ?? `${d.title} — AI Nights KI-Assistent`}
  description={d.seo?.description ?? d.excerpt ?? `${d.title} — ein KI-Assistent der AI Nights.`}
  path={`/ai-assistants/${d.slug}/`}
  image={d.image?.src}
  ogType="article"
>
  <Header lang="de" />
  <main class="container detail section">
    <a href="/ai-assistants/" class="back">← Alle KI-Assistenten</a>
    <div class="head">
      {d.image?.src && <img class="icon" src={d.image.src} alt={d.image.alt ?? d.title} width="120" height="120" />}
      <div>
        <p class="eyebrow">KI-Assistent</p>
        <h1 class="display-font">{d.title}</h1>
        {d.excerpt && <p class="tagline">{d.excerpt}</p>}
        {d.link && <a href={d.link} target="_blank" rel="noopener" class="btn btn-primary">Assistent öffnen</a>}
      </div>
    </div>
    {d.contentHtml && <div class="prose" set:html={d.contentHtml} />}
  </main>
  <Footer lang="de" />
</Layout>

<style>
  .detail {
    max-width: 780px;
    padding-block: 2.5rem 3rem;
  }
  .back {
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .back:hover {
    color: var(--magenta-bright);
  }
  .head {
    display: flex;
    gap: 1.8rem;
    align-items: center;
    margin: 1.5rem 0 2.5rem;
    flex-wrap: wrap;
  }
  .icon {
    width: 110px;
    height: 110px;
    border-radius: 22px;
    object-fit: cover;
    border: 1px solid var(--border);
  }
  h1 {
    font-size: clamp(1.8rem, 4.5vw, 2.8rem);
    margin: 0.3rem 0 0.7rem;
  }
  .tagline {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin-bottom: 1.2rem;
    max-width: 50ch;
  }
</style>
