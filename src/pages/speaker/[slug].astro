---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const { isPlaceholderSpeaker } = await import('../../lib/speakers');
  const speakers = await getCollection('speaker');
  return speakers
    .filter((s) => !isPlaceholderSpeaker(s))
    .map((s) => ({ params: { slug: s.data.slug }, props: { s } }));
}

const { s } = Astro.props;
const d = s.data;

// Sessions dieses Speakers
const allSessions = await getCollection('sessions');
const sessions = allSessions.filter(
  (se) => se.data.speakerSlugs?.includes(d.slug) || (d.id && se.data.speakerIds?.includes(d.id)),
);

const socialLinks = [
  d.socials?.instagram && ['Instagram', d.socials.instagram.startsWith('http') ? d.socials.instagram : `https://instagram.com/${d.socials.instagram.replace('@', '')}`],
  d.socials?.tiktok && ['TikTok', d.socials.tiktok.startsWith('http') ? d.socials.tiktok : `https://tiktok.com/@${d.socials.tiktok.replace('@', '')}`],
  d.socials?.x && ['X', d.socials.x.startsWith('http') ? d.socials.x : `https://x.com/${d.socials.x.replace('@', '')}`],
  d.socials?.linkedin && ['LinkedIn', d.socials.linkedin],
  d.socials?.website && ['Website', d.socials.website],
  ...(d.links ?? []).map((l) => [l.label, l.url]),
].filter(Boolean) as [string, string][];
---

<Layout
  lang="de"
  title={d.seo?.title ?? `${d.title} — AI Nights Speaker`}
  description={d.seo?.description ?? d.excerpt ?? `${d.title}${d.jobTitle ? `, ${d.jobTitle}` : ''} — Speaker bei den AI Nights.`}
  path={`/speaker/${d.slug}/`}
  image={d.image?.src}
  ogType="profile"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: d.title,
    jobTitle: d.jobTitle,
    description: d.excerpt,
    image: d.image?.src ? `https://ainights.ai${d.image.src}` : undefined,
    url: `https://ainights.ai/speaker/${d.slug}/`,
  }}
>
  <Header lang="de" />
  <main class="container detail">
    <a href="/speaker/" class="back">← Alle Speaker</a>
    <div class="head">
      {d.image?.src && (
        <div class="portrait">
          <img src={d.image.src} alt={d.image.alt ?? d.title} width="480" height="480" />
        </div>
      )}
      <div class="intro">
        <p class="eyebrow">Speaker</p>
        <h1 class="display-font">{d.title}</h1>
        {d.jobTitle && <p class="role">{d.jobTitle}</p>}
        {socialLinks.length > 0 && (
          <div class="socials">
            {socialLinks.map(([label, href]) => (
              <a href={href} target="_blank" rel="noopener">{label}</a>
            ))}
          </div>
        )}
      </div>
    </div>

    {d.bioHtml && <div class="prose" set:html={d.bioHtml} />}

    {(d.topics?.length ?? 0) > 0 && (
      <section class="extra">
        <h2 class="display-font">Themen &amp; Schwerpunkte</h2>
        <ul class="topic-list">
          {d.topics!.map((t) => <li>{t}</li>)}
        </ul>
      </section>
    )}

    {(d.keyTakeaways?.length ?? 0) > 0 && (
      <section class="extra">
        <h2 class="display-font">Key Takeaways</h2>
        <ul class="takeaways">
          {d.keyTakeaways!.map((t) => <li>{t}</li>)}
        </ul>
      </section>
    )}

    {sessions.length > 0 && (
      <section class="talks">
        <h2 class="display-font">Sessions</h2>
        <ul>
          {sessions.map((se) => (
            <li>
              <a href={`/sessions/${se.data.slug}/`}>{se.data.title}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="value">
      <p class="eyebrow">AI Nights Speaker</p>
      <h2 class="display-font">Speaker bei den AI&nbsp;Nights</h2>
      <div class="value-grid">
        <div class="v"><strong>Ausgezeichnete Fachexpertise</strong><span>Menschen, die KI wirklich einsetzen – mit echter Praxis statt Buzzwords.</span></div>
        <div class="v"><strong>Unterhaltsamer Vortragsstil</strong><span>Kurze, pointierte Sessions, die informieren und Spaß machen.</span></div>
        <div class="v"><strong>Topaktuelles Wissen</strong><span>Frische Perspektiven auf die Themen, die gerade wirklich zählen.</span></div>
      </div>
    </section>

    <section class="become card">
      <p class="eyebrow">Gemeinsam mehr Wert liefern</p>
      <h2 class="display-font">Speaker werden</h2>
      <p>Du hast ein spannendes Thema und möchtest selbst auf der AI&nbsp;Nights Bühne stehen?</p>
      <a href="/de/speaker-application/" class="btn btn-primary">Jetzt Speaker werden</a>
    </section>
  </main>
  <Footer lang="de" />
</Layout>

<style>
  .detail {
    padding-block: 2.5rem 3rem;
    max-width: 860px;
  }
  .back {
    display: inline-block;
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }
  .back:hover {
    color: var(--magenta-bright);
  }
  .head {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 2.5rem;
    align-items: center;
    margin-bottom: 2.5rem;
  }
  .portrait img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0.4rem 0 0.6rem;
  }
  .role {
    color: var(--text-secondary);
    font-size: 1.1rem;
    font-weight: 500;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .socials {
    display: flex;
    gap: 0.8rem;
    margin-top: 1.2rem;
    flex-wrap: wrap;
  }
  .socials a {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.4rem 1rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }
  .socials a:hover {
    border-color: var(--magenta-bright);
    color: var(--text-primary);
  }
  .prose {
    color: var(--text-secondary);
    font-size: 1.08rem;
    line-height: 1.75;
  }
  .prose :global(p) {
    margin-bottom: 1.2rem;
  }
  .extra {
    margin-top: 2.5rem;
    border-top: 1px solid var(--border);
    padding-top: 2rem;
  }
  .extra h2 {
    font-size: 1.4rem;
    margin-bottom: 1rem;
  }
  .topic-list,
  .takeaways {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .topic-list li,
  .takeaways li {
    position: relative;
    padding-left: 1.6rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .topic-list li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--blue-bright);
    font-weight: 700;
  }
  .takeaways li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--magenta-bright);
    font-weight: 700;
  }
  .talks {
    margin-top: 3rem;
    border-top: 1px solid var(--border);
    padding-top: 2rem;
  }
  .talks h2 {
    font-size: 1.4rem;
    margin-bottom: 1rem;
  }
  .talks ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .talks a {
    color: var(--text-primary);
  }
  .talks a:hover {
    color: var(--magenta-bright);
  }
  .value {
    margin-top: 3.5rem;
    border-top: 1px solid var(--border);
    padding-top: 2.5rem;
  }
  .value h2 {
    font-size: 1.5rem;
    margin: 0.4rem 0 1.5rem;
  }
  .value-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.25rem;
  }
  .value .v {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .value .v strong {
    color: var(--text-primary);
    font-size: 1.02rem;
  }
  .value .v span {
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .become {
    margin-top: 2.5rem;
    padding: 2.5rem;
    text-align: center;
  }
  .become h2 {
    font-size: 1.8rem;
    margin: 0.3rem 0 0.8rem;
  }
  .become p {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }
  @media (max-width: 640px) {
    .head {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .portrait {
      max-width: 240px;
    }
  }
</style>
