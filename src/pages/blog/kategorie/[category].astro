---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import BlogGrid from '../../../components/BlogGrid.astro';
import { BLOG_CATEGORIES, type BlogCategory } from '../../../lib/blog';

export function getStaticPaths() {
  return Object.keys(BLOG_CATEGORIES).map((category) => ({ params: { category } }));
}

const category = Astro.params.category as BlogCategory;
const meta = BLOG_CATEGORIES[category];

const isDev = import.meta.env.DEV;
const posts = (await getCollection('blog'))
  .filter((p) => p.data.category === category)
  .filter((p) => isDev || (!p.data.draft && p.data.pubDate.getTime() <= Date.now()))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout
  lang="de"
  title={`${meta.label} — AI Nights Blog`}
  description={meta.description}
  path={`/blog/kategorie/${category}/`}
  alternates={{ de: `/blog/kategorie/${category}/` }}
>
  <Header lang="de" />
  <main class="container archive section">
    <p class="eyebrow">AI Nights Blog</p>
    <h1 class="display-font">{meta.label}</h1>
    <p class="sub">{meta.description}</p>

    <nav class="cat-filter" aria-label="Blog-Kategorien">
      <a href="/blog/" class="filter-btn">Alle</a>
      {Object.entries(BLOG_CATEGORIES).map(([slug, c]) => (
        <a
          href={`/blog/kategorie/${slug}/`}
          class:list={['filter-btn', { active: slug === category }]}
          aria-current={slug === category ? 'page' : undefined}
        >
          {c.label}
        </a>
      ))}
    </nav>

    {posts.length === 0 && (
      <div class="empty card">
        <h2 class="display-font">Hier erscheint bald etwas ✨</h2>
        <p>In dieser Kategorie gibt es noch keine Beiträge — schau bald wieder vorbei.</p>
        <a href="/blog/" class="btn btn-primary">Alle Beiträge ansehen</a>
      </div>
    )}

    <BlogGrid posts={posts} />
  </main>
  <Footer lang="de" />
</Layout>

<style>
  .archive {
    padding-block: 3rem 4rem;
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin: 0.4rem 0 0.8rem;
  }
  .sub {
    color: var(--text-secondary);
    max-width: 62ch;
    margin-bottom: 1.8rem;
    font-size: 1.05rem;
  }
  .cat-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2.2rem;
  }
  .filter-btn {
    border: 1px solid var(--border-strong);
    color: var(--text-secondary);
    border-radius: 999px;
    padding: 0.5rem 1.2rem;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .filter-btn:hover {
    border-color: var(--magenta-bright);
    color: var(--text-primary);
  }
  .filter-btn.active {
    background: var(--gradient-accent);
    border-color: transparent;
    color: #fff;
  }
  .empty {
    padding: 3rem 2rem;
    text-align: center;
  }
  .empty h2 {
    font-size: 1.6rem;
    margin-bottom: 0.8rem;
  }
  .empty p {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }
</style>
