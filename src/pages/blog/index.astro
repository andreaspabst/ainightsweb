---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogGrid from '../../components/BlogGrid.astro';
import { BLOG_CATEGORIES, isPublished } from '../../lib/blog';

// Sichtbarkeit zentral in lib/blog.ts: Dev + lokaler Preview zeigen auch
// Drafts/geplante Beiträge (mit Badge), der Forge-Build blendet sie aus.
const posts = (await getCollection('blog'))
  .filter(isPublished)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout
  lang="de"
  title="Blog — AI Nights"
  description="Der AI Nights Blog: Speaker-Ankündigungen, News aus der Community und Content rund um Künstliche Intelligenz aus Nürnberg und München."
  path="/blog/"
  alternates={{ de: '/blog/' }}
>
  <Header lang="de" />
  <main class="container archive section">
    <p class="eyebrow">Neues von den AI Nights</p>
    <h1 class="display-font">Blog</h1>
    <p class="sub">Speaker-Ankündigungen, News aus der Community und Content rund um KI.</p>

    <nav class="cat-filter" aria-label="Blog-Kategorien">
      <a href="/blog/" class="filter-btn active" aria-current="page">Alle</a>
      {Object.entries(BLOG_CATEGORIES).map(([slug, c]) => (
        <a href={`/blog/kategorie/${slug}/`} class="filter-btn">{c.label}</a>
      ))}
    </nav>

    {posts.length === 0 && (
      <div class="empty card">
        <h2 class="display-font">Bald geht's los ✨</h2>
        <p>Hier erscheinen in Kürze Recaps und Artikel rund um die AI&nbsp;Nights. Bis dahin: Schau bei unseren Events vorbei!</p>
        <a href="/events/" class="btn btn-primary">Zu den Events</a>
      </div>
    )}

    <BlogGrid posts={posts} />
  </main>
  <Footer lang="de" />
</Layout>

<style>
  .archive {
    padding-block: 3rem 4rem;
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin: 0.4rem 0 0.8rem;
  }
  .sub {
    color: var(--text-secondary);
    max-width: 56ch;
    margin-bottom: 1.8rem;
    font-size: 1.05rem;
  }
  .cat-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2.2rem;
  }
  .filter-btn {
    border: 1px solid var(--border-strong);
    color: var(--text-secondary);
    border-radius: 999px;
    padding: 0.5rem 1.2rem;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .filter-btn:hover {
    border-color: var(--magenta-bright);
    color: var(--text-primary);
  }
  .filter-btn.active {
    background: var(--gradient-accent);
    border-color: transparent;
    color: #fff;
  }
  .empty {
    padding: 3rem 2rem;
    text-align: center;
  }
  .empty h2 {
    font-size: 1.6rem;
    margin-bottom: 0.8rem;
  }
  .empty p {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }
</style>
