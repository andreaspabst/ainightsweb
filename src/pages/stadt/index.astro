---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CityMap from '../../components/CityMap.astro';
import { CITIES, cityColor } from '../../lib/cities';

const shown = CITIES.filter((c) => c.onOverview);
const active = shown.filter((c) => c.status === 'active');
const soon = shown.filter((c) => c.status === 'soon');
---

<Layout
  lang="de"
  title="Städte — AI Nights"
  description="Die AI Nights Städte im Überblick: Afterwork-Events rund um Künstliche Intelligenz in Nürnberg und München — bald auch in Hamburg, Bayreuth und Barcelona."
  path="/stadt/"
  alternates={{ de: '/stadt/' }}
>
  <Header lang="de" />
  <main class="container archive section">
    <p class="eyebrow">Live vor Ort</p>
    <h1 class="display-font">Unsere Städte</h1>
    <p class="sub">
      Die AI&nbsp;Nights sind eine wachsende Event-Reihe: gestartet in Nürnberg, inzwischen auch in München — und weitere
      Städte stehen schon in den Startlöchern.
    </p>

    <div class="map-wrap card">
      <CityMap />
    </div>
    <p class="map-credit">Kartenbasis: Natural Earth (Public Domain)</p>

    <h2 class="group display-font">Hier sind wir aktiv</h2>
    <div class="grid">
      {active.map((c) => (
        <a href={`/stadt/${c.slug}/`} class="city card">
          <span class="city-badge" style={`background: ${cityColor(c.name)}`}>Aktiv</span>
          <h3 class="display-font">{c.name}</h3>
          <p>Regelmäßige Afterwork-Events mit Talks, Live-Demos und Community.</p>
          <span class="more">Zur Stadt →</span>
        </a>
      ))}
    </div>

    <h2 class="group display-font">Bald am Start</h2>
    <div class="grid">
      {soon.map((c) => (
        <a href={`/stadt/${c.slug}/`} class="city card soon-card">
          <span class="city-badge soon-badge">Bald</span>
          <h3 class="display-font">{c.name}</h3>
          <p>Die AI&nbsp;Nights kommen — Termin wird noch bekanntgegeben.</p>
          <span class="more">Mehr erfahren →</span>
        </a>
      ))}
    </div>
  </main>
  <Footer lang="de" />
</Layout>

<style>
  .archive {
    padding-block: 3rem 4rem;
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin: 0.4rem 0 0.8rem;
  }
  .sub {
    color: var(--text-secondary);
    max-width: 56ch;
    margin-bottom: 2.5rem;
    font-size: 1.05rem;
  }
  .map-wrap {
    padding: 1.5rem;
    overflow: hidden;
  }
  .map {
    position: relative;
  }
  .map img {
    width: 100%;
    height: auto;
    display: block;
  }
  .map-credit {
    margin-top: 0.6rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }
  .map-credit a {
    color: var(--text-muted);
    text-decoration: underline;
  }
  .group {
    font-size: 1.4rem;
    margin: 2.5rem 0 1.3rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .city {
    padding: 1.6rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  .city:hover {
    transform: translateY(-4px);
    border-color: var(--border-strong);
  }
  .city-badge {
    align-self: flex-start;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
  }
  .soon-badge {
    background: var(--bg-elevated);
    border: 1px solid var(--border-strong);
    color: var(--text-muted);
  }
  .city h3 {
    font-size: 1.3rem;
    color: var(--text-primary);
  }
  .city p {
    color: var(--text-secondary);
    font-size: 0.92rem;
    line-height: 1.6;
  }
  .soon-card {
    opacity: 0.85;
  }
  .more {
    margin-top: auto;
    padding-top: 0.5rem;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--magenta-bright);
  }
</style>
