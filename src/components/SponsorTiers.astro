---
import { getCollection } from 'astro:content';

export interface Props {
  lang?: 'de' | 'en';
}
const { lang = 'de' } = Astro.props;

const sponsors = await getCollection('sponsor');
const tierOrder = ['platin', 'gold', 'silver', 'bronce'];
const labels: Record<string, Record<string, string>> = {
  de: { platin: 'Platin Sponsoren', gold: 'Gold Sponsoren', silver: 'Silver Sponsoren', bronce: 'Bronze Sponsoren' },
  en: { platin: 'Platinum Sponsors', gold: 'Gold Sponsors', silver: 'Silver Sponsors', bronce: 'Bronze Sponsors' },
};
const groups = tierOrder
  .map((tier) => ({ tier, label: labels[lang][tier], items: sponsors.filter((s) => s.data.tier === tier) }))
  .filter((g) => g.items.length);
---

<div class="tiers">
  {groups.map((group) => (
    <div class="tier">
      <h2 class="tier-label">{group.label}</h2>
      <div class="row">
        {group.items.map((s) => (
          <a href={`/sponsor/${s.data.slug}/`} class="sponsor card" title={s.data.title}>
            <div class="logo">
              <img src={s.data.logo?.src ?? s.data.image?.src} alt={s.data.title} loading="lazy" />
            </div>
            <div class="txt">
              <strong>{s.data.title}</strong>
              {s.data.excerpt && <span>{s.data.excerpt}</span>}
            </div>
          </a>
        ))}
      </div>
    </div>
  ))}
</div>

<style>
  .tier {
    margin-bottom: 2.8rem;
  }
  .tier-label {
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.2rem;
    text-align: center;
  }
  .row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.25rem;
  }
  .sponsor {
    display: flex;
    flex-direction: column;
    width: 240px;
    padding: 1.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  .sponsor:hover {
    transform: translateY(-3px);
    border-color: var(--border-strong);
  }
  .logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 72px;
    margin-bottom: 1rem;
  }
  .logo img {
    max-height: 56px;
    max-width: 170px;
    object-fit: contain;
  }
  .txt {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    text-align: center;
  }
  .txt strong {
    color: var(--text-primary);
    font-size: 1rem;
  }
  .txt span {
    color: var(--text-muted);
    font-size: 0.85rem;
    line-height: 1.45;
  }
</style>
