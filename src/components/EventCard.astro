---
import { cityColor } from '../lib/cities';
import { imgVariant } from '../lib/images';

export interface Props {
  slug: string;
  title: string;
  city?: string;
  eventDate?: string;
  locationName?: string;
  image?: { src?: string; alt?: string };
  excerpt?: string;
  ticketUrl?: string;
}
const { slug, title, city, eventDate, locationName, image, excerpt, ticketUrl } = Astro.props;

function fmtDate(d?: string) {
  if (!d) return null;
  const parsed = new Date(d.replace(' ', 'T'));
  if (isNaN(parsed.getTime())) return d;
  return parsed.toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' });
}
const dateLabel = fmtDate(eventDate);
---

<article class="event-card card">
  <a href={`/events/${slug}/`} class="cover">
    {image?.src && <img src={imgVariant(image.src, 640)} alt={image.alt ?? title} loading="lazy" width="640" height="400" />}
    {city && <span class="city-badge" style={`background: ${cityColor(city)}`}>{city}</span>}
  </a>
  <div class="body">
    {dateLabel && <p class="date">{dateLabel}</p>}
    <h3><a href={`/events/${slug}/`}>{title}</a></h3>
    {locationName && <p class="loc">📍 {locationName}</p>}
    {excerpt && <p class="excerpt">{excerpt}</p>}
    <div class="actions">
      <a href={`/events/${slug}/`} class="btn btn-ghost">Details</a>
      {ticketUrl && <a href={ticketUrl} class="btn btn-primary">Tickets</a>}
    </div>
  </div>
</article>

<style>
  .event-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  .event-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-strong);
  }
  .cover {
    position: relative;
    aspect-ratio: 16 / 10;
    background: var(--bg-elevated);
    display: block;
    overflow: hidden;
  }
  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .city-badge {
    position: absolute;
    top: 0.9rem;
    left: 0.9rem;
    background: var(--gradient-accent);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
  }
  .body {
    padding: 1.2rem 1.3rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .date {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--blue-bright);
  }
  h3 {
    font-size: 1.2rem;
  }
  h3 a {
    color: var(--text-primary);
  }
  h3 a:hover {
    color: var(--magenta-bright);
  }
  .loc {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .excerpt {
    font-size: 0.9rem;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .actions {
    margin-top: auto;
    padding-top: 0.8rem;
    display: flex;
    gap: 0.6rem;
  }
  .actions .btn {
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
  }
</style>
